{
  "name": "devpilot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "powershell -ExecutionPolicy Bypass -File scripts/tauri-env.ps1 dev",
    "tauri:build": "powershell -ExecutionPolicy Bypass -File scripts/tauri-env.ps1 build",
    "tauri:build:no-bundle": "powershell -ExecutionPolicy Bypass -File scripts/tauri-env.ps1 build --no-bundle"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~5.8.0",
    "vite": "^8.1.3",
    "vue-tsc": "^2.2.12"
  }
}
